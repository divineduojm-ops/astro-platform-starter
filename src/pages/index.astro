---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Full Cycle Accounting — Bookkeeping for Small Businesses in Michigan">
    <!-- HEADER / NAV -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-warm-white/90 backdrop-blur-md border-b border-border">
        <div class="container flex items-center justify-between h-16 sm:h-20">
            <a href="#" class="text-lg sm:text-xl font-bold text-text no-underline tracking-tight">
                Full Cycle Accounting
            </a>
            <nav class="hidden sm:flex items-center gap-8">
                <a href="#services" class="text-sm text-text-light no-underline hover:text-primary transition-colors">Services</a>
                <a href="#about" class="text-sm text-text-light no-underline hover:text-primary transition-colors">About</a>
                <a href="#how-it-works" class="text-sm text-text-light no-underline hover:text-primary transition-colors">How It Works</a>
                <a href="#contact" class="btn text-sm !py-2.5 !px-5">Book a Call</a>
            </nav>
            <button id="mobile-menu-btn" class="sm:hidden p-2 text-text-light cursor-pointer bg-transparent border-0" aria-label="Toggle menu">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="sm:hidden hidden border-t border-border bg-warm-white">
            <div class="container py-4 flex flex-col gap-4">
                <a href="#services" class="text-text-light no-underline hover:text-primary transition-colors mobile-nav-link">Services</a>
                <a href="#about" class="text-text-light no-underline hover:text-primary transition-colors mobile-nav-link">About</a>
                <a href="#how-it-works" class="text-text-light no-underline hover:text-primary transition-colors mobile-nav-link">How It Works</a>
                <a href="#contact" class="btn text-center mobile-nav-link">Book a Call</a>
            </div>
        </div>
    </header>

    <!-- HERO SECTION -->
    <section class="pt-32 sm:pt-40 pb-16 sm:pb-24" style="background: linear-gradient(180deg, var(--color-sage-light) 0%, var(--color-warm-white) 100%);">
        <div class="container max-w-3xl text-center">
            <h1 class="mb-6 leading-tight">
                Behind on your books and dreading tax season?
            </h1>
            <p class="text-lg sm:text-xl text-text-light mb-10 max-w-2xl mx-auto leading-relaxed">
                I help small business owners in Michigan get their finances in order — so you can stop guessing and start growing with confidence.
            </p>
            <a href="#contact" class="btn btn-lg">Book a Free Consultation</a>
        </div>
    </section>

    <!-- SERVICES SECTION -->
    <section id="services" class="section section-alt scroll-mt-20">
        <div class="container">
            <div class="text-center mb-14">
                <h2 class="mb-4">How I Can Help</h2>
                <p class="text-text-light max-w-xl mx-auto">
                    Whether you need ongoing support or help cleaning up the past, I offer services that meet you where you are.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
                <!-- Service 1 -->
                <div class="card flex flex-col">
                    <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5" style="background-color: var(--color-sage);">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="mb-3">Monthly Bookkeeping</h3>
                    <p class="text-text-light text-sm leading-relaxed mb-4 grow">
                        Your books, reconciled and up to date every month. Includes categorizing transactions, bank reconciliation, monthly financial reports, and a check-in so you actually understand what the numbers mean. Best for business owners who want to stay on top of their finances without doing it themselves.
                    </p>
                    <p class="text-primary font-semibold text-sm">Starting at $300/month</p>
                </div>

                <!-- Service 2 -->
                <div class="card flex flex-col">
                    <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5" style="background-color: var(--color-blush);">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                    </div>
                    <h3 class="mb-3">Catch-Up Bookkeeping</h3>
                    <p class="text-text-light text-sm leading-relaxed mb-4 grow">
                        Months (or years) behind? No judgment — just results. I'll clean up your books, reconcile your accounts, and get everything current so you can move forward with a clear picture. Perfect if you've been putting off your bookkeeping and need a fresh start.
                    </p>
                    <p class="text-primary font-semibold text-sm">Custom pricing based on scope</p>
                </div>

                <!-- Service 3 -->
                <div class="card flex flex-col">
                    <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5" style="background-color: var(--color-lavender-light);">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" style="color: #8b7fb5;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    </div>
                    <h3 class="mb-3">CFO Advisory</h3>
                    <p class="text-text-light text-sm leading-relaxed mb-4 grow">
                        More than bookkeeping — this is strategic financial guidance. I'll help you read your reports, plan for growth, manage cash flow, and make confident decisions about hiring, spending, and scaling. Ideal for business owners who want a financial partner, not just a number cruncher.
                    </p>
                    <p class="text-primary font-semibold text-sm">Starting at $750/month</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about" class="section scroll-mt-20">
        <div class="container">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
                <div class="md:col-span-4 flex justify-center">
                    <div class="w-56 h-56 sm:w-64 sm:h-64 rounded-full flex items-center justify-center" style="background-color: var(--color-sage);">
                        <span class="text-5xl font-bold text-primary/40">TM</span>
                    </div>
                </div>
                <div class="md:col-span-8">
                    <h2 class="mb-2">Hi, I'm Trea Manson</h2>
                    <p class="text-primary font-medium mb-6">Founder, Full Cycle Accounting</p>
                    <div class="space-y-4 text-text-light leading-relaxed">
                        <p>
                            I built Full Cycle Accounting because too many business owners were stuck between two bad options: a basic bookkeeper who just records transactions, or an expensive CPA firm focused on taxes and audits. Neither one helps you actually understand and use your numbers to grow.
                        </p>
                        <p>
                            When we work together, you get a financial partner who keeps your books clean, delivers reports you can actually read, and sits down with you to talk through what the numbers mean for your next move. Whether that's hiring, expanding, cutting costs, or just sleeping better at night.
                        </p>
                        <p>
                            I work with nonprofits, growing businesses, and established companies. I handle everything except tax preparation, and I collaborate closely with your CPA so nothing falls through the cracks.
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-3 mt-8">
                        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium" style="background-color: var(--color-sage); color: var(--color-primary-dark);">
                            FCA Certified
                        </span>
                        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium" style="background-color: var(--color-sage); color: var(--color-primary-dark);">
                            QuickBooks ProAdvisor
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS SECTION -->
    <section id="how-it-works" class="section section-alt scroll-mt-20">
        <div class="container">
            <div class="text-center mb-14">
                <h2 class="mb-4">How It Works</h2>
                <p class="text-text-light max-w-xl mx-auto">
                    Getting started is simple. Here's what to expect.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 max-w-4xl mx-auto">
                <!-- Step 1 -->
                <div class="text-center">
                    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5" style="background-color: var(--color-sage);">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                    </div>
                    <div class="text-sm font-semibold text-primary mb-2">Step 1</div>
                    <h3 class="mb-2 text-lg">Book a Free Intro Call</h3>
                    <p class="text-text-light text-sm leading-relaxed">
                        A quick 15-minute conversation to learn about your business and what you need. No pressure, no pitch.
                    </p>
                </div>

                <!-- Step 2 -->
                <div class="text-center">
                    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5" style="background-color: var(--color-blush);">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                        </svg>
                    </div>
                    <div class="text-sm font-semibold text-accent mb-2">Step 2</div>
                    <h3 class="mb-2 text-lg">I Review Your Books & Create a Plan</h3>
                    <p class="text-text-light text-sm leading-relaxed">
                        I'll look at where things stand and put together a clear plan — what needs to happen, in what order, and what it'll cost.
                    </p>
                </div>

                <!-- Step 3 -->
                <div class="text-center">
                    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5" style="background-color: var(--color-lavender-light);">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" style="color: #8b7fb5;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div class="text-sm font-semibold" style="color: #8b7fb5;">Step 3</div>
                    <h3 class="mb-2 text-lg">You Focus on Your Business</h3>
                    <p class="text-text-light text-sm leading-relaxed">
                        I get to work on your books. You get monthly reports, regular check-ins, and the peace of mind that comes from knowing your numbers are handled.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- TESTIMONIALS SECTION -->
    <section class="section scroll-mt-20">
        <div class="container">
            <div class="text-center mb-14">
                <h2 class="mb-4">What My Clients Say</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                <div class="card">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-4 text-sage" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                    </svg>
                    <p class="text-text-light leading-relaxed mb-6">
                        She makes sure I understand my numbers and actually feel confident in them. She doesn't just keep my books organized — she helps me make better decisions. She helps me make more money. And she cares about me just as much as she cares about the health of my business.
                    </p>
                    <p class="font-semibold text-sm text-text">— Detroit Mom</p>
                </div>
                <div class="card">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mb-4 text-sage" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                    </svg>
                    <p class="text-text-light leading-relaxed mb-6">
                        Trea is the kind of accountant who makes money feel human. She's smart, funny, and easy to talk to — and she never makes you feel judged for what you don't know. I trust her completely with both the details and the big picture.
                    </p>
                    <p class="font-semibold text-sm text-text">— Small Business Owner</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT SECTION -->
    <section id="contact" class="section section-alt scroll-mt-20">
        <div class="container">
            <div class="max-w-2xl mx-auto">
                <div class="text-center mb-10">
                    <h2 class="mb-4">Let's Talk About Your Books</h2>
                    <p class="text-text-light">
                        Ready to get your finances in order? Fill out the form below and I'll be in touch within one business day.
                    </p>
                </div>
                <form name="contact" method="POST" data-netlify="true" class="space-y-5">
                    <input type="hidden" name="form-name" value="contact" />
                    <div>
                        <label for="name" class="block text-sm font-medium text-text mb-1.5">Name <span class="text-accent">*</span></label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            class="w-full px-4 py-3 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                            placeholder="Your name"
                        />
                    </div>
                    <div>
                        <label for="email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-accent">*</span></label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            class="w-full px-4 py-3 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                            placeholder="you@example.com"
                        />
                    </div>
                    <div>
                        <label for="phone" class="block text-sm font-medium text-text mb-1.5">Phone <span class="text-text-lighter">(optional)</span></label>
                        <input
                            type="tel"
                            id="phone"
                            name="phone"
                            class="w-full px-4 py-3 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                            placeholder="(555) 123-4567"
                        />
                    </div>
                    <div>
                        <label for="message" class="block text-sm font-medium text-text mb-1.5">Message <span class="text-accent">*</span></label>
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            required
                            class="w-full px-4 py-3 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"
                            placeholder="Tell me a little about your business and what you need help with..."
                        ></textarea>
                    </div>
                    <div class="pt-2">
                        <button type="submit" class="btn btn-lg w-full sm:w-auto">Get in Touch</button>
                    </div>
                </form>
                <div class="mt-10 pt-8 border-t border-border text-center">
                    <p class="text-text-light text-sm mb-2">
                        Or reach out directly:
                    </p>
                    <p class="text-sm">
                        <a href="mailto:trea@fullcycleaccounting.com" class="text-primary font-medium">trea@fullcycleaccounting.com</a>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="py-10 border-t border-border">
        <div class="container text-center">
            <p class="font-semibold text-text mb-2">Full Cycle Accounting</p>
            <p class="text-text-light text-sm mb-1">
                <a href="mailto:trea@fullcycleaccounting.com" class="text-text-light hover:text-primary">trea@fullcycleaccounting.com</a>
            </p>
            <p class="text-text-lighter text-xs mt-4">&copy; 2026 Full Cycle Accounting. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // Mobile menu toggle
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        if (menuBtn && mobileMenu) {
            menuBtn.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });

            // Close mobile menu when a nav link is clicked
            const mobileLinks = mobileMenu.querySelectorAll('.mobile-nav-link');
            mobileLinks.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.add('hidden');
                });
            });
        }
    </script>
</Layout>
